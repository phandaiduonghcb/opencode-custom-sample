# =============================================================================
# DevOps Automation System - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control!
# =============================================================================

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Port the Express server listens on
PORT=3000

# Environment mode (development, production, test)
NODE_ENV=production

# Logging level (error, warn, info, debug)
LOG_LEVEL=info

# -----------------------------------------------------------------------------
# OpenCode SDK Configuration
# -----------------------------------------------------------------------------
# OpenCode API key - Get from https://opencode.ai
# REQUIRED: This is needed for AI-powered workflow execution
OPENCODE_API_KEY=your-opencode-api-key-here

# OpenCode server port (if running local OpenCode instance)
OPENCODE_PORT=4097

# OpenCode model to use for workflow execution
OPENCODE_MODEL=opencode/minimax-m2.5-free

# -----------------------------------------------------------------------------
# Workspace Configuration
# -----------------------------------------------------------------------------
# Directory where temporary workflow workspaces are created
# Each workflow execution gets its own subdirectory
WORKSPACE_ROOT=/tmp/workflows

# Maximum number of concurrent workflow executions
# Prevents resource exhaustion from too many parallel workflows
MAX_CONCURRENT_WORKFLOWS=5

# Workflow execution timeout in seconds (default: 3600 = 1 hour)
WORKFLOW_TIMEOUT=3600

# -----------------------------------------------------------------------------
# Azure Authentication
# -----------------------------------------------------------------------------
# Azure App Registration credentials for service principal authentication
# Create an App Registration in Azure Portal → Azure Active Directory
# REQUIRED: These are needed for Azure DevOps and resource access

# Application (client) ID from App Registration
AZURE_CLIENT_ID=your-app-registration-client-id

# Client secret from App Registration (Certificates & secrets)
AZURE_CLIENT_SECRET=your-app-registration-secret

# Directory (tenant) ID from App Registration
AZURE_TENANT_ID=your-azure-tenant-id

# -----------------------------------------------------------------------------
# Azure DevOps Configuration
# -----------------------------------------------------------------------------
# Azure DevOps organization and project for pipeline operations
# REQUIRED: These are needed for PR creation and pipeline monitoring

# Organization name (from URL: https://dev.azure.com/{organization})
AZURE_DEVOPS_ORG=your-organization-name

# Project name within the organization
AZURE_DEVOPS_PROJECT=your-project-name

# Default Azure DevOps API version (usually don't need to change)
AZURE_DEVOPS_API_VERSION=7.0

# -----------------------------------------------------------------------------
# Repository Configuration
# -----------------------------------------------------------------------------
# Default target branch for pull requests (if not specified in API request)
DEFAULT_TARGET_BRANCH=develop

# Git user configuration for commits
GIT_USER_NAME=DevOps Automation Bot
GIT_USER_EMAIL=devops-automation@example.com

# -----------------------------------------------------------------------------
# Pipeline Configuration
# -----------------------------------------------------------------------------
# Pipeline monitoring poll interval in seconds
PIPELINE_POLL_INTERVAL=30

# Pipeline monitoring timeout in seconds (default: 1800 = 30 minutes)
PIPELINE_TIMEOUT=1800

# Maximum number of fix iterations per workflow (prevents infinite loops)
MAX_FIX_ITERATIONS=5

# -----------------------------------------------------------------------------
# Deployment Validation Configuration
# -----------------------------------------------------------------------------
# Deployment health check timeout in seconds
DEPLOYMENT_HEALTH_TIMEOUT=300

# Deployment health check retry interval in seconds
DEPLOYMENT_HEALTH_RETRY_INTERVAL=10

# -----------------------------------------------------------------------------
# Kubernetes Configuration (if using AKS deployments)
# -----------------------------------------------------------------------------
# Default namespace for Kubernetes operations
K8S_DEFAULT_NAMESPACE=default

# Kubeconfig path (optional, uses default if not set)
# KUBECONFIG=/path/to/kubeconfig

# -----------------------------------------------------------------------------
# Security Configuration
# -----------------------------------------------------------------------------
# API authentication token (optional, for securing API endpoints)
# API_AUTH_TOKEN=your-secret-token-here

# Enable/disable API authentication (true/false)
# API_AUTH_ENABLED=false

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Enable detailed debug logging for OpenCode SDK interactions
DEBUG_OPENCODE=false

# Enable detailed debug logging for Azure CLI commands
DEBUG_AZURE_CLI=false

# Enable automatic workspace cleanup after workflow completion
AUTO_CLEANUP_WORKSPACE=true
